<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_view_form_inherit_quality" model="ir.ui.view">
        <field name="name">mrp.production.view.form.inherit.quality</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button string="Quality Checks" name="check_quality" type="object" class="oe_highlight" data-hotkey="shift+z"
                        invisible="not quality_check_todo or state in ('done', 'cancel')" groups="esl_quality_control.group_quality_user"/>
                <button name="button_quality_alert" groups="esl_quality_control.group_quality_user" type="object" string="Quality Alert" context="{'default_production_id': id}" class="oe_highlight" invisible="not quality_check_fail or quality_alert_count != 0" data-hotkey="shift+q"/>
            </xpath>
            <div name="button_box" position="inside">
                <button name="open_quality_alert_production" groups="esl_quality_control.group_quality_user" type="object" class="oe_stat_button" icon="fa-bell" invisible="quality_alert_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value"><field name="quality_alert_count"/></span>
                        <span class="o_stat_text">Quality Alert</span>
                    </div>
                </button>
                <button name="action_open_quality_check_production" groups="esl_quality_control.group_quality_user" invisible="not check_ids or quality_check_fail or not quality_check_todo" type="object" class="oe_stat_button" icon="fa-check">
                    <span class="o_stat_text">Quality Checks</span>
                </button>
                <button name="action_open_quality_check_production" groups="esl_quality_control.group_quality_user" invisible="not check_ids or quality_check_fail or quality_check_todo" type="object" class="oe_stat_button text-success" icon="fa-check">
                    <span class="o_stat_text text-success">Quality Checks</span>
                </button>
                <button name="action_open_quality_check_production" groups="esl_quality_control.group_quality_user" invisible="not check_ids or not quality_check_fail" type="object" class="oe_stat_button text-danger" icon="fa-check">
                    <span class="o_stat_text text-danger">Quality Checks</span>
                </button>
            </div>
        </field>
    </record>

    <record id="mrp_production_view_tree_inherit_quality" model="ir.ui.view">
        <field name="name">mrp.production.view.list.inherit.quality</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="quality_check_todo" column_invisible="True"/>
            </xpath>
        </field>
    </record>

    <record id="mrp_production_view_search_inherit_quality" model="ir.ui.view">
        <field name="name">mrp.production.view.search.inherit.quality</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.view_mrp_production_filter"/>
        <field name="arch" type="xml">
           <xpath expr="//search" position="inside">
                <filter name="quality_check_todo" string="Quality Checks" domain="[('quality_check_todo', '=', True)]"/>
           </xpath>
        </field>
    </record>
</odoo>
