<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit BOM Form View -->
    <record id="mrp_bom_form_view_inherit_customer" model="ir.ui.view">
        <field name="name">mrp.bom.form.inherit.customer</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="partner_id" widget="res_partner_many2one" context="{'res_partner_search_mode': 'customer'}"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit BOM List (Tree) View -->
    <record id="mrp_bom_tree_view_inherit_customer" model="ir.ui.view">
        <field name="name">mrp.bom.list.inherit.customer</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="partner_id" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit BOM Search View to filter/group by Customer -->
    <record id="view_mrp_bom_filter_inherit_customer" model="ir.ui.view">
        <field name="name">mrp.bom.select.inherit.customer</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.view_mrp_bom_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="partner_id" string="Customer"/>
                <filter string="Customer" name="group_by_customer" domain="[]" context="{'group_by': 'partner_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
